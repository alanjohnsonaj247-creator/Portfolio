# Nodemailer SMTP Configuration Settings

# Hostname of the SMTP server (e.g., smtp.gmail.com for Gmail, smtp.resend.com for Resend)
SMTP_HOST=smtp.gmail.com

# Port of the SMTP server (usually 587 for TLS, or 465 for SSL)
SMTP_PORT=587

# Set to true if using SSL port 465, false if using TLS port 587
SMTP_SECURE=false

# Your email address (e.g., yourgmail@gmail.com)
SMTP_USER=adansonjala123@gmail.com

# Your SMTP password (e.g., Gmail App Password)
SMTP_PASS=yfwdwmrpfhsegmdu

# Recipient email address where contact form submissions will be sent.
# If left blank, emails will be sent to SMTP_USER.
CONTACT_RECIPIENT=alanjohnsonaj247@gmail.com
